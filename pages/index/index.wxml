<navigation-bar title="Maze Duel" back="{{false}}" color="black" background="#f7f1e6"></navigation-bar>
<view class="page">
  <view class="hud-card">
    <view class="hud-row">
      <text class="hud-label">我方 HP</text>
      <text class="hud-value">{{hpText}}</text>
    </view>
    <view class="hud-row">
      <text class="hud-label">敌方 HP</text>
      <text class="hud-value danger">{{enemyHpText}}</text>
    </view>
    <view class="hud-row">
      <text class="hud-label">弹药</text>
      <text class="hud-value">{{ammoText}}</text>
    </view>
    <view class="hud-row">
      <text class="hud-label">时间</text>
      <text class="hud-value">{{timeText}}</text>
    </view>
    <text class="status-text">{{statusText}}</text>
  </view>

  <canvas id="game-canvas" type="2d" class="game-canvas"></canvas>

  <view class="control-panel">
    <view class="dpad">
      <view class="dpad-row">
        <view class="control-spacer"></view>
        <view
          class="control-button"
          data-key="up"
          bindtouchstart="handleControlStart"
          bindtouchend="handleControlEnd"
          bindtouchcancel="handleControlEnd"
        >↑</view>
        <view class="control-spacer"></view>
      </view>
      <view class="dpad-row">
        <view
          class="control-button"
          data-key="left"
          bindtouchstart="handleControlStart"
          bindtouchend="handleControlEnd"
          bindtouchcancel="handleControlEnd"
        >←</view>
        <view
          class="control-button restart"
          bindtap="startNewGame"
        >重开</view>
        <view
          class="control-button"
          data-key="right"
          bindtouchstart="handleControlStart"
          bindtouchend="handleControlEnd"
          bindtouchcancel="handleControlEnd"
        >→</view>
      </view>
      <view class="dpad-row">
        <view class="control-spacer"></view>
        <view
          class="control-button"
          data-key="down"
          bindtouchstart="handleControlStart"
          bindtouchend="handleControlEnd"
          bindtouchcancel="handleControlEnd"
        >↓</view>
        <view class="control-spacer"></view>
      </view>
    </view>

    <view class="shoot-wrap">
      <view class="shoot-button" bindtap="handleShootTap">开火</view>
    </view>
  </view>
</view>
