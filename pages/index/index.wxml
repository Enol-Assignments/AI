<navigation-bar title="Maze Duel" back="{{false}}" color="black" background="#f7f1e6"></navigation-bar>
<view class="page-shell">
  <view class="top-panel">
    <view class="top-row">
      <view class="hud-card">
        <view class="hud-grid">
          <view class="hud-item">
            <text class="hud-label">我方 HP</text>
            <text class="hud-value">{{hpText}}</text>
          </view>
          <view class="hud-item">
            <text class="hud-label">敌方 HP</text>
            <text class="hud-value danger">{{enemyHpText}}</text>
          </view>
          <view class="hud-item">
            <text class="hud-label">弹药</text>
            <text class="hud-value">{{ammoText}}</text>
          </view>
          <view class="hud-item">
            <text class="hud-label">时间</text>
            <text class="hud-value">{{timeText}}</text>
          </view>
        </view>
        <text class="status-text">{{statusText}}</text>
      </view>
      <view class="top-actions">
        <view class="restart-button" bindtap="resetGame">重开</view>
        <text class="action-tip">摇杆定朝向，按住开火</text>
      </view>
    </view>

    <view class="skills-container">
      <view class="skills-panel player-skills">
        <view class="skills-title">我方技能</view>
        <view class="skills-grid">
          <view
            wx:for="{{skills}}"
            wx:key="id"
            class="skill-button {{item.available ? (item.selected ? 'selected' : 'available') : 'cooldown'}}"
            data-skill-id="{{item.id}}"
            bindtap="handleSkillTap"
          >
            <view class="skill-name">{{item.name}}</view>
            <view class="skill-cooldown" wx:if="{{!item.available}}">{{item.cooldown.toFixed(1)}}s</view>
          </view>
        </view>
      </view>

      <view class="skills-panel enemy-skills">
        <view class="skills-title">敌方技能</view>
        <view class="skills-grid">
          <view
            wx:for="{{enemySkills}}"
            wx:key="id"
            class="skill-button {{item.selected ? 'selected' : 'available'}} enemy-chip"
          >
            <view class="skill-name">{{item.name}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="arena-card">
    <canvas id="game-canvas" type="2d" class="game-canvas" style="height: {{canvasHeightPx}}px;"></canvas>
  </view>

  <view class="control-panel">
    <view class="control-card joystick-card">
      <text class="control-title">移动</text>
      <view
        id="move-pad"
        class="joystick-pad"
        bindtouchstart="handleJoystickStart"
        bindtouchmove="handleJoystickMove"
        bindtouchend="handleJoystickEnd"
        bindtouchcancel="handleJoystickEnd"
      >
        <view class="joystick-core"></view>
        <view class="joystick-knob" style="transform: translate({{joystickOffsetX}}px, {{joystickOffsetY}}px);"></view>
      </view>
    </view>

    <view class="control-card fire-card">
      <text class="control-title">射击</text>
      <view
        class="fire-button {{shooting ? 'active' : ''}}"
        bindtouchstart="handleShootStart"
        bindtouchend="handleShootEnd"
        bindtouchcancel="handleShootEnd"
      >开火</view>
      <text class="fire-tip">子弹固定朝当前前进方向</text>
    </view>
  </view>
</view>
