page {
  background: linear-gradient(180deg, #f9f4eb 0%, #eadfcb 100%);
}

.page-shell {
  height: 100vh;
  padding: 14rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  overflow: hidden;
}

.top-panel {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.top-row {
  display: flex;
  gap: 10rpx;
  align-items: stretch;
}

.hud-card,
.skills-panel,
.control-card,
.arena-card {
  background: rgba(255, 250, 242, 0.92);
  border: 2rpx solid rgba(73, 57, 44, 0.12);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(73, 57, 44, 0.08);
}

.hud-card {
  flex: 1;
  padding: 14rpx 16rpx;
}

.hud-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  column-gap: 20rpx;
  row-gap: 10rpx;
}

.hud-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #4a3b2f;
  font-size: 24rpx;
}

.hud-label {
  opacity: 0.78;
}

.hud-value {
  font-weight: 700;
}

.danger {
  color: #c44f4f;
}

.status-text {
  display: block;
  margin-top: 8rpx;
  color: #6a5848;
  font-size: 21rpx;
  line-height: 1.28;
}

.top-actions {
  width: 168rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 8rpx;
}

.restart-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 78rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #ffd28f 0%, #f0a952 100%);
  color: #5a3816;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(173, 107, 30, 0.22);
}

.action-tip {
  color: #7b6757;
  font-size: 18rpx;
  line-height: 1.35;
  padding: 0 4rpx;
}

.skills-container {
  display: flex;
  gap: 8rpx;
}

.skills-panel {
  flex: 1;
  padding: 8rpx;
}

.skills-title {
  font-size: 18rpx;
  font-weight: 700;
  color: #4a3b2f;
  margin-bottom: 6rpx;
  text-align: center;
}

.skills-grid {
  display: flex;
  gap: 4rpx;
}

.skill-button {
  position: relative;
  flex: 1;
  min-height: 52rpx;
  padding: 6rpx 3rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(73, 57, 44, 0.08);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.player-skills {
  border-left: 4rpx solid #2f7cf6;
}

.enemy-skills {
  border-left: 4rpx solid #f25f5c;
}

.skill-button.available {
  background: linear-gradient(135deg, #e8f5e8 0%, #d4edda 100%);
  border: 2rpx solid #c3e6cb;
}

.skill-button.selected {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border: 3rpx solid #2196f3;
  box-shadow: 0 0 16rpx rgba(33, 150, 243, 0.45);
}

.enemy-chip.selected {
  background: linear-gradient(135deg, #ffe3de 0%, #ffc5bc 100%);
  border: 2rpx solid #ef8b7c;
  box-shadow: none;
}

.skill-button.cooldown {
  background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
  border: 2rpx solid #f1b0b7;
  opacity: 0.72;
}

.skill-name {
  font-size: 14rpx;
  font-weight: 600;
  color: #4a3b2f;
  text-align: center;
  line-height: 1.2;
}

.skill-cooldown {
  position: absolute;
  right: 4rpx;
  bottom: 4rpx;
  font-size: 12rpx;
  font-weight: 700;
  color: #c44f4f;
  background: rgba(255, 255, 255, 0.85);
  padding: 0 4rpx;
  border-radius: 6rpx;
}

.arena-card {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 8rpx;
  overflow: hidden;
}

.game-canvas {
  width: 100%;
  border-radius: 28rpx;
  overflow: hidden;
  background: #f4efe5;
}

.control-panel {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.control-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx;
  min-height: 196rpx;
}

.control-title {
  color: #5e4c3e;
  font-size: 20rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.joystick-pad {
  position: relative;
  width: 168rpx;
  height: 168rpx;
  border-radius: 84rpx;
  background:
    radial-gradient(circle at center, rgba(255,255,255,0.75) 0 28%, transparent 29% 100%),
    linear-gradient(180deg, rgba(105, 83, 65, 0.08) 0%, rgba(105, 83, 65, 0.16) 100%);
  border: 4rpx solid rgba(87, 69, 55, 0.14);
  box-shadow: inset 0 8rpx 18rpx rgba(91, 74, 58, 0.08);
}

.joystick-pad::before,
.joystick-pad::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  background: rgba(87, 69, 55, 0.08);
  transform: translate(-50%, -50%);
}

.joystick-pad::before {
  width: 8rpx;
  height: 112rpx;
}

.joystick-pad::after {
  width: 112rpx;
  height: 8rpx;
}

.joystick-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 34rpx;
  height: 34rpx;
  margin-left: -17rpx;
  margin-top: -17rpx;
  border-radius: 50%;
  background: rgba(91, 74, 58, 0.18);
}

.joystick-knob {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 74rpx;
  height: 74rpx;
  margin-left: -37rpx;
  margin-top: -37rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fffaf2 0%, #e7d8c5 100%);
  box-shadow: 0 12rpx 22rpx rgba(73, 57, 44, 0.22);
}

.fire-card {
  gap: 12rpx;
}

.fire-button {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 156rpx;
  height: 156rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff996d 0%, #e95b4c 100%);
  color: #fff8f2;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 30rpx rgba(220, 101, 73, 0.3);
}

.fire-button.active {
  transform: scale(0.96);
  box-shadow: 0 10rpx 18rpx rgba(220, 101, 73, 0.4);
}

.fire-tip {
  color: #7b6757;
  font-size: 18rpx;
  line-height: 1.3;
  text-align: center;
}
