JavaScriptfunction checkBulletHit(bullet, entity) {
  const dx = bullet.x - entity.x;
  const dy = bullet.y - entity.y;
  const distSq = dx*dx + dy*dy;
  return distSq < (bullet.radius + entity.radius) ** 2;
}
